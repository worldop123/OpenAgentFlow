# OpenAgentFlow 环境变量配置示例

# 应用配置
APP_NAME=OpenAgentFlow
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据库配置
DATABASE_URL=sqlite:///./openagentflow.db
# 或使用 PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/openagentflow

# AI模型配置 (必需)
OPENAI_API_KEY=sk-your-openai-api-key-here
# 或使用其他兼容API:
# OPENAI_BASE_URL=https://api.openai.com/v1
# 或使用 Azure OpenAI:
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/
# OPENAI_API_KEY=your-azure-openai-key
# OPENAI_API_VERSION=2023-12-01-preview

DEFAULT_MODEL=gpt-3.5-turbo
# 可选模型: gpt-4, gpt-4-turbo, claude-3-opus, etc.

# 飞书配置 (可选)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 钉钉配置 (可选)
DINGTALK_APP_KEY=your_dingtalk_app_key
DINGTALK_APP_SECRET=your_dingtalk_app_secret

# 企业微信配置 (可选)
WECOM_CORP_ID=your_wecom_corp_id
WECOM_CORP_SECRET=your_wecom_corp_secret

# 日志配置
LOG_LEVEL=INFO
# 可选: DEBUG, INFO, WARNING, ERROR

# 安全配置
SECRET_KEY=your-secret-key-for-jwt-tokens
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置 (前端开发时使用)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000